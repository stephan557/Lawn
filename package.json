{
  "name": "lawn-booking",
  "version": "1.0.0",
  "description": "Lawn Mowing Date Booking Website",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "build": "pkg . --targets node18-win-x64 --output dist/lawnbooking.exe"
  },
  "bin": "server.js",
  "pkg": {
    "assets": [
      "public/**/*"
    ],
    "targets": [
      "node18-win-x64"
    ],
    "outputPath": "dist"
  },
  "dependencies": {
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "nodemailer": "^8.0.6"
  },
  "devDependencies": {
    "pkg": "^5.8.1"
  }
}
